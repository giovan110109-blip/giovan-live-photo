{
  "name": "giovan-live-photo",
  "version": "1.0.6",
  "description": "A Vue 3 component library for playing Live Photos",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./vue": {
      "types": "./dist/vue/index.d.ts",
      "import": "./dist/vue/index.mjs",
      "require": "./dist/vue/index.js"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build --mode lib",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.vue",
    "test": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "live-photo",
    "photo",
    "video",
    "vue",
    "vue3"
  ],
  "author": "giovan",
  "license": "MIT",
  "dependencies": {
    "thumbhash": "^0.1.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/test-utils": "^2.4.0",
    "typescript": "~5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.7.0",
    "vitest": "^1.0.0",
    "vue": "^3.4.0"
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/giovan110109-blip/giovan-live-photo.git"
  },
  "bugs": {
    "url": "https://github.com/giovan110109-blip/giovan-live-photo/issues"
  },
  "homepage": "https://github.com/giovan110109-blip/giovan-live-photo#readme"
}
